@page "/"
@inject IDbContextFactory<PlutusDbContext> DbFactory
@inject ISpendingReport SpendingReport
@inject NavigationManager Nav

<PageTitle>Plutus — Dashboard</PageTitle>

@if (_loading)
{
    <div class="loading-text" style="margin-top:3rem">
        <div class="loading-spinner"></div>
        Loading…
    </div>
}
else
{
    <div class="page-header">
        <div class="page-title">Dashboard</div>
        <div class="page-title-sub">@DateTime.Now.ToString("dddd, MMMM d, yyyy").ToUpper()</div>
    </div>

    <div class="card-grid">
        <div class="stat-card">
            <div class="stat-label">Needs Review</div>
            <div class="stat-value @(_needsReview > 0 ? "highlight" : "")">@_needsReview</div>
            @if (_needsReview > 0)
            {
                <a href="review" class="muted" style="font-size:.78rem; text-decoration:none; color:var(--accent);">Review now →</a>
            }
            else
            {
                <span class="muted">All clear</span>
            }
        </div>

        <div class="stat-card">
            <div class="stat-label">Last Sync</div>
            @if (_lastRun is null)
            {
                <div class="stat-value" style="font-size:1rem; color:var(--gray)">Never</div>
                <span class="muted">Connect SimpleFIN in Settings</span>
            }
            else
            {
                var ok = _lastRun.Status == SyncStatus.Success;
                <div class="stat-value" style="font-size:1rem; display:flex; align-items:center; gap:.35rem">
                    <span class="status-dot @(ok ? "ok" : "bad")"></span>@_lastRun.Status
                </div>
                <span class="muted">@_lastRun.RanAt.ToLocalTime().ToString("MMM d · h:mm tt") · @_lastRun.NewTransactionCount new</span>
            }
        </div>
    </div>

    <div class="section-label" style="margin-top:2rem">This Month · Spending by Category</div>
    <div class="card">
        @if (_spend.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📊</div>
                <p style="font-weight:600; color:var(--text); margin-bottom:.35rem">No spending data yet</p>
                <p>Categorized transactions will appear here once synced.</p>
            </div>
        }
        else
        {
            <RadzenChart SeriesClick="@OnSeriesClick" Style="@_chartStyle">
                <RadzenBarSeries TItem="CategorySpend"
                                 Data="@_spend"
                                 CategoryProperty="Name"
                                 ValueProperty="Total"
                                 Fills="@_fills"
                                 Title="Spending" />
                <RadzenValueAxis Formatter="@FormatAsCurrency">
                    <RadzenAxisTitle Text="Amount ($)" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        }
    </div>

    <div class="section-label" style="margin-top:2rem">Accounts</div>

    @if (_accounts.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🏦</div>
            <p style="font-weight:600; color:var(--text); margin-bottom:.35rem">No accounts connected</p>
            <p><a href="settings" style="color:var(--accent); text-decoration:none">Connect SimpleFIN in Settings</a> to start syncing.</p>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var account in _accounts)
            {
                <div class="stat-card">
                    <div class="stat-label">@account.Name</div>
                    <div class="stat-value amount" style="font-size:1.4rem">@Money.Plain(account.Balance)</div>
                    <span class="muted">@(account.Org ?? account.Currency)</span>
                </div>
            }
        </div>
    }
}

@code {
    private bool _loading = true;
    private List<Account> _accounts = [];
    private int _needsReview;
    private SyncRun? _lastRun;
    private IReadOnlyList<CategorySpend> _spend = [];
    private IEnumerable<string> _fills = [];
    private string _chartStyle = "height:300px";

    private const string GrayFallback = "#808184";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _accounts = await db.Accounts.AsNoTracking().OrderBy(a => a.Name).ToListAsync();
        _needsReview = await db.Transactions.CountAsync(t => !t.IsReviewed);
        _lastRun = await db.SyncRuns.AsNoTracking().OrderByDescending(r => r.RanAt).FirstOrDefaultAsync();

        _spend = await SpendingReport.GetMonthlySpendingAsync(DateTime.Now.Year, DateTime.Now.Month);
        _fills = _spend.Select(s => s.Color ?? GrayFallback).ToList();
        _chartStyle = $"height:{_spend.Count * 44 + 60}px";

        _loading = false;
    }

    private string FormatAsCurrency(object value)
    {
        if (value is double d)
            return $"${d:N0}";
        return value?.ToString() ?? "";
    }

    private void OnSeriesClick(SeriesClickEventArgs args)
    {
        if (args.Data is not CategorySpend row)
            return;

        var url = row.CategoryId is null
            ? "/transactions?category=uncategorized"
            : $"/transactions?category={row.CategoryId}";

        Nav.NavigateTo(url);
    }
}
