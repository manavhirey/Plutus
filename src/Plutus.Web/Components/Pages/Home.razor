@page "/"
@inject IDbContextFactory<PlutusDbContext> DbFactory

<PageTitle>Plutus — Dashboard</PageTitle>

@if (_loading)
{
    <div class="loading-text" style="margin-top:3rem">
        <div class="loading-spinner"></div>
        Loading…
    </div>
}
else
{
    <div class="page-header">
        <div class="page-title">Dashboard</div>
        <div class="page-title-sub">@DateTime.Now.ToString("dddd, MMMM d, yyyy").ToUpper()</div>
    </div>

    <div class="card-grid">
        <div class="stat-card">
            <div class="stat-label">Needs Review</div>
            <div class="stat-value @(_needsReview > 0 ? "highlight" : "")">@_needsReview</div>
            @if (_needsReview > 0)
            {
                <a href="review" class="muted" style="font-size:.78rem; text-decoration:none; color:var(--accent);">Review now →</a>
            }
            else
            {
                <span class="muted">All clear</span>
            }
        </div>

        <div class="stat-card">
            <div class="stat-label">Last Sync</div>
            @if (_lastRun is null)
            {
                <div class="stat-value" style="font-size:1rem; color:var(--gray)">Never</div>
                <span class="muted">Connect SimpleFIN in Settings</span>
            }
            else
            {
                var ok = _lastRun.Status == SyncStatus.Success;
                <div class="stat-value" style="font-size:1rem; display:flex; align-items:center; gap:.35rem">
                    <span class="status-dot @(ok ? "ok" : "bad")"></span>@_lastRun.Status
                </div>
                <span class="muted">@_lastRun.RanAt.ToLocalTime().ToString("MMM d · h:mm tt") · @_lastRun.NewTransactionCount new</span>
            }
        </div>
    </div>

    <div class="section-label" style="margin-top:2rem">Accounts</div>

    @if (_accounts.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🏦</div>
            <p style="font-weight:600; color:var(--text); margin-bottom:.35rem">No accounts connected</p>
            <p><a href="settings" style="color:var(--accent); text-decoration:none">Connect SimpleFIN in Settings</a> to start syncing.</p>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var account in _accounts)
            {
                <div class="stat-card">
                    <div class="stat-label">@account.Name</div>
                    <div class="stat-value amount" style="font-size:1.4rem">@Money.Plain(account.Balance)</div>
                    <span class="muted">@(account.Org ?? account.Currency)</span>
                </div>
            }
        </div>
    }
}

@code {
    private bool _loading = true;
    private List<Account> _accounts = [];
    private int _needsReview;
    private SyncRun? _lastRun;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _accounts = await db.Accounts.AsNoTracking().OrderBy(a => a.Name).ToListAsync();
        _needsReview = await db.Transactions.CountAsync(t => !t.IsReviewed);
        _lastRun = await db.SyncRuns.AsNoTracking().OrderByDescending(r => r.RanAt).FirstOrDefaultAsync();
        _loading = false;
    }
}
