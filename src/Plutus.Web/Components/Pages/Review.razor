@page "/review"
@inject IDbContextFactory<PlutusDbContext> DbFactory
@inject ICategorizer Categorizer
@inject TimeProvider Time

<PageTitle>Plutus — Review</PageTitle>

<div class="page-header">
    <div class="page-title">Daily Review</div>
    @if (!_loading && _items.Count > 0)
    {
        <div class="page-title-sub">@_items.Count TRANSACTION@(_items.Count == 1 ? "" : "S") PENDING</div>
    }
</div>

@if (_loading)
{
    <div class="loading-text">
        <div class="loading-spinner"></div>
        Loading…
    </div>
}
else if (_items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">✓</div>
        <p style="font-weight:600; color:var(--text); margin-bottom:.35rem">All caught up</p>
        <p>No transactions pending review.</p>
    </div>
}
else
{
    <div class="review-stack">
        @foreach (var item in _items)
        {
            <div class="review-card">
                <div class="review-head">
                    <div class="review-meta">
                        <span class="review-date">@item.PostedDate.ToLocalTime().ToString("MMM d, yyyy")</span>
                        <span class="review-desc">@item.Description</span>
                    </div>
                    <span class="review-amount">@Money.Expense(item.Amount)</span>
                </div>

                <div class="review-fields">
                    <div class="field" style="margin-bottom:0">
                        <label>
                            Category
                            @if (item.HasSuggestion && item.SelectedCategoryId == item.OriginalCategoryId)
                            {
                                <span class="suggested-badge">AI suggested</span>
                            }
                            @if (item.Refining)
                            {
                                <span class="suggested-badge" style="opacity:.6">Refining…</span>
                            }
                        </label>
                        <select @bind="item.SelectedCategoryId">
                            <option value="0">Uncategorized</option>
                            @foreach (var category in _categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                    </div>

                    <div class="field" style="margin-bottom:0">
                        <label>
                            Note
                            @if (item.HasNoteSuggestion && !NoteEdited(item))
                            {
                                <span class="suggested-badge">AI suggested</span>
                            }
                        </label>
                        <input type="text" @bind="item.Note" @bind:after="() => RefineFromNoteAsync(item)" placeholder="e.g. birthday gift for Sam" />
                    </div>
                </div>

                <div class="review-actions">
                    <button class="btn btn-primary" disabled="@(item.Saving || item.Refining)" @onclick="() => SaveAsync(item)">
                        @(item.Saving ? "Saving…" : "Confirm →")
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<Category> _categories = [];
    private readonly List<ReviewItem> _items = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _categories = await db.Categories.AsNoTracking().OrderBy(c => c.SortOrder).ToListAsync();

        var pending = await db.Transactions.AsNoTracking()
            .Where(t => !t.IsReviewed)
            .OrderByDescending(t => t.PostedDate)
            .ToListAsync();

        foreach (var t in pending)
        {
            _items.Add(new ReviewItem
            {
                Id = t.Id,
                Description = t.Description,
                Amount = t.Amount,
                PostedDate = t.PostedDate,
                OriginalCategoryId = t.CategoryId ?? 0,
                SelectedCategoryId = t.CategoryId ?? 0,
                Note = t.Note,
                OriginalNote = t.Note,
                HasSuggestion = t.CategoryId is not null,
                HasNoteSuggestion = !string.IsNullOrWhiteSpace(t.Note),
            });
        }

        _loading = false;
    }

    private async Task SaveAsync(ReviewItem item)
    {
        item.Saving = true;

        var note = NormalizeNote(item.Note);
        int? categoryId = item.SelectedCategoryId == 0 ? null : item.SelectedCategoryId;

        await using var db = await DbFactory.CreateDbContextAsync();
        var transaction = await db.Transactions.FirstOrDefaultAsync(t => t.Id == item.Id);
        if (transaction is not null)
        {
            transaction.Note = note;
            transaction.CategoryId = categoryId;
            transaction.IsCategorized = categoryId is not null;
            transaction.IsReviewed = true;
            transaction.CategorizedAt = categoryId is not null ? Time.GetUtcNow().UtcDateTime : transaction.CategorizedAt;
            await db.SaveChangesAsync();
        }

        _items.Remove(item);
    }

    private async Task RefineFromNoteAsync(ReviewItem item)
    {
        // Only refine when the note actually changed from the loaded suggestion and is non-empty.
        var note = NormalizeNote(item.Note);
        if (!NoteEdited(item) || note is null)
        {
            return;
        }
        item.Refining = true;
        try
        {
            var result = await Categorizer.CategorizeAsync(item.Description, note, _categories);
            if (result is not null)
            {
                var match = _categories.FirstOrDefault(
                    c => string.Equals(c.Name, result.Category, StringComparison.OrdinalIgnoreCase));
                if (match is not null)
                {
                    item.SelectedCategoryId = match.Id; // live update — user sees the refined category
                }
            }
            // On failure/no-match: leave the dropdown as-is so the user can pick; nothing silent.
        }
        finally
        {
            item.Refining = false;
        }
    }

    private static string? NormalizeNote(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static bool NoteEdited(ReviewItem item) =>
        !string.Equals(NormalizeNote(item.Note), NormalizeNote(item.OriginalNote), StringComparison.Ordinal);

    private sealed class ReviewItem
    {
        public int Id { get; init; }
        public string Description { get; init; } = "";
        public decimal Amount { get; init; }
        public DateTime PostedDate { get; init; }
        public int OriginalCategoryId { get; init; }
        public int SelectedCategoryId { get; set; }
        public string? Note { get; set; }
        public string? OriginalNote { get; init; }
        public bool HasSuggestion { get; init; }
        public bool HasNoteSuggestion { get; init; }
        public bool Saving { get; set; }
        public bool Refining { get; set; }
    }
}
