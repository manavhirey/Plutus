@page "/not-found"
@layout MainLayout

<div style="text-align:center; padding:4rem 2rem; max-width:480px; margin:0 auto">
    <div style="font-family:var(--font-mono); font-size:3rem; color:var(--text-dim); margin-bottom:1rem">404</div>
    <h1 style="font-size:1.3rem; margin-bottom:.5rem; color:var(--text)">Page not found</h1>
    <p style="color:var(--text-muted); margin-bottom:2rem; font-size:.9rem">The content you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary" style="text-decoration:none">← Back to Dashboard</a>
</div>
