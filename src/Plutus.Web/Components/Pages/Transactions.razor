@page "/transactions"
@inject IDbContextFactory<PlutusDbContext> DbFactory
@using System.Globalization

<PageTitle>Plutus — Transactions</PageTitle>

<div class="filter-row">
    <div class="page-title">Transactions</div>
    <div class="row-inline">
        <span class="muted" style="font-size:.78rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em">Filter</span>
        <select @bind="_categoryFilter" @bind:after="LoadAsync" class="filter-select">
            <option value="0">All categories</option>
            <option value="-1">Uncategorized</option>
            @foreach (var category in _categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
    </div>
</div>

@if (_loading)
{
    <div class="loading-text">
        <div class="loading-spinner"></div>
        Loading transactions…
    </div>
}
else if (_transactions.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <p style="font-weight:600; color:var(--text); margin-bottom:.35rem">No transactions</p>
        <p>Nothing to show for the current filter.</p>
    </div>
}
else
{
    @foreach (var day in _transactions
        .GroupBy(t => t.PostedDate.ToLocalTime().Date)
        .OrderByDescending(g => g.Key))
    {
        <div class="day-header">
            <span class="day">@day.Key.ToString("dddd, MMM d, yyyy")</span>
            <span class="total amount">@Money.Expense(day.Sum(t => t.Amount))</span>
        </div>
        <div class="card txn-table-card" style="padding:.25rem 1rem; margin-bottom:.25rem">
            <table>
                <tbody>
                    @foreach (var txn in day.OrderByDescending(t => t.PostedDate))
                    {
                        <tr class="txn-row txn-row-clickable" @onclick="() => _editingId = txn.Id">
                            <td class="txn-desc" style="color:var(--text)">@txn.Description</td>
                            <td class="txn-cat">
                                @if (txn.Category is not null)
                                {
                                    <span class="chip" style="background:@(txn.Category.Color ?? "#4a4f65")">@txn.Category.Name</span>
                                }
                                else
                                {
                                    <span style="color:var(--gray-lt); font-size:.8rem">Uncategorized</span>
                                }
                            </td>
                            <td class="txn-amount amount amount-expense">@Money.Expense(txn.Amount)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<TransactionEditPanel TransactionId="_editingId"
                      Categories="_categories"
                      OnSaved="OnEditSavedAsync"
                      OnClosed="() => _editingId = null" />

@code {
    // Query-string parameter: numeric id, "uncategorized", or absent/"0"
    [SupplyParameterFromQuery(Name = "category")]
    public string? CategoryParam { get; set; }

    private bool _loading = true;
    // Sentinel: 0 = all, -1 = uncategorized, >0 = specific category id
    private int _categoryFilter; // 0 = all
    private List<Category> _categories = [];
    private List<Transaction> _transactions = [];
    private int? _editingId;

    protected override async Task OnInitializedAsync()
    {
        _categoryFilter = ParseCategoryParam(CategoryParam);

        await using var db = await DbFactory.CreateDbContextAsync();
        _categories = await db.Categories.AsNoTracking().OrderBy(c => c.SortOrder).ToListAsync();
        await LoadAsync();
    }

    // Maps a raw query-string value to the sentinel int.
    // "uncategorized" → -1, positive numeric id → that id, anything else → 0 (all)
    private static int ParseCategoryParam(string? param)
    {
        if (string.IsNullOrWhiteSpace(param)) return 0;
        if (param.Equals("uncategorized", StringComparison.OrdinalIgnoreCase)) return -1;
        if (int.TryParse(param, NumberStyles.Integer, CultureInfo.InvariantCulture, out var id) && id > 0) return id;
        return 0;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Transactions.AsNoTracking().Include(t => t.Category).AsQueryable();
        if (_categoryFilter == -1)
        {
            query = query.Where(t => t.CategoryId == null);
        }
        else if (_categoryFilter > 0)
        {
            query = query.Where(t => t.CategoryId == _categoryFilter);
        }
        // _categoryFilter == 0 → no filter (all transactions)

        _transactions = await query
            .OrderByDescending(t => t.PostedDate)
            .Take(500)
            .ToListAsync();
        _loading = false;
    }

    private async Task OnEditSavedAsync()
    {
        _editingId = null;
        await LoadAsync(); // re-applies the current filter; a row moved out of it drops
    }
}
