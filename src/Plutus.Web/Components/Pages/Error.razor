@page "/Error"
@using System.Diagnostics

<PageTitle>Error — Plutus</PageTitle>

<div style="text-align:center; padding:4rem 2rem; max-width:480px; margin:0 auto">
    <div style="font-family:var(--font-mono); font-size:3rem; color:var(--crimson); margin-bottom:1rem; opacity:.6">ERR</div>
    <h1 style="font-size:1.3rem; margin-bottom:.5rem; color:var(--text)">Something went wrong</h1>
    <p style="color:var(--text-muted); margin-bottom:2rem; font-size:.9rem">An unhandled error occurred while processing your request.</p>

    @if (ShowRequestId)
    {
        <div style="background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:.75rem 1rem; text-align:left; margin-bottom:1.5rem">
            <span style="font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-dim); display:block; margin-bottom:.25rem">Request ID</span>
            <code style="font-family:var(--font-mono); font-size:.82rem; color:var(--text-muted); word-break:break-all">@RequestId</code>
        </div>
    }

    <p style="color:var(--text-dim); font-size:.8rem; line-height:1.7">
        Enable the <strong style="color:var(--text-muted)">Development</strong> environment for detailed diagnostics.
        Do not enable it in production — it may expose sensitive exception information.
    </p>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
