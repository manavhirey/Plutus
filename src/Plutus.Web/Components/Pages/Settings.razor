@page "/settings"
@inject IDbContextFactory<PlutusDbContext> DbFactory
@inject ISimpleFinConnectionService ConnectionService
@inject Microsoft.Extensions.Options.IOptions<SyncOptions> SyncOptions

<PageTitle>Plutus — Settings</PageTitle>

<div class="page-header">
    <div class="page-title">Settings</div>
</div>

@if (_bannerMessage is not null)
{
    <div class="banner @(_bannerOk ? "banner-success" : "banner-error")">
        @if (_bannerOk)
        {
            <span>✓</span>
        }
        else
        {
            <span>✕</span>
        }
        @_bannerMessage
    </div>
}

<div class="section-label">SimpleFIN Connection</div>
<div class="card settings-section">
    <div class="connection-status">
        @if (_connection is null)
        {
            <span class="status-dot none"></span>
            <span class="muted">Not connected</span>
        }
        else
        {
            <span class="status-dot ok"></span>
            <span>Connected since @_connection.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
            @if (_connection.LastSyncedAt is { } last)
            {
                <span class="muted" style="margin-left:auto">Last synced @last.ToLocalTime().ToString("MMM d · h:mm tt")</span>
            }
            else
            {
                <span class="muted" style="margin-left:auto">Not yet synced</span>
            }
        }
    </div>

    <div class="field">
        <label>Setup Token</label>
        <input type="password" @bind="_setupToken" placeholder="Paste your SimpleFIN setup token (Base64, single-use)" />
    </div>
    <div class="row-inline" style="justify-content:flex-end">
        <button class="btn btn-primary" disabled="@(_connecting || string.IsNullOrWhiteSpace(_setupToken))" @onclick="ConnectAsync">
            @(_connecting ? "Connecting…" : _connection is null ? "Connect" : "Reconnect")
        </button>
    </div>
</div>

<div class="section-label">Categories</div>
<div class="card settings-section" style="padding:.5rem 1.25rem">
    <table>
        <thead>
            <tr>
                <th style="width:60px">Order</th>
                <th>Name</th>
                <th style="width:130px">Color</th>
                <th style="width:170px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in _categories)
            {
                <tr class="txn-row">
                    <td><input type="number" @bind="category.SortOrder" style="width:56px" /></td>
                    <td>
                        <div class="row-inline" style="gap:.6rem">
                            @if (!string.IsNullOrWhiteSpace(category.Color))
                            {
                                <div class="color-preview" style="background:@category.Color"></div>
                            }
                            <input type="text" @bind="category.Name" />
                        </div>
                    </td>
                    <td><input type="text" @bind="category.Color" placeholder="#hex" /></td>
                    <td style="text-align:right">
                        <div class="row-inline" style="justify-content:flex-end">
                            <button class="btn btn-sm" @onclick="() => SaveCategoryAsync(category)">Save</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteCategoryAsync(category.Id)">Delete</button>
                        </div>
                    </td>
                </tr>
            }
            <tr class="txn-row">
                <td></td>
                <td><input type="text" @bind="_newCategoryName" placeholder="New category name" /></td>
                <td><input type="text" @bind="_newCategoryColor" placeholder="#4F46E5" /></td>
                <td style="text-align:right">
                    <button class="btn btn-sm btn-primary" disabled="@string.IsNullOrWhiteSpace(_newCategoryName)" @onclick="AddCategoryAsync">Add</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="section-label">Sync History</div>
<div class="card settings-section" style="padding:.5rem 1.25rem">
    <p class="muted" style="padding:.5rem 0; margin:0">Automatic daily sync at <span style="font-family:var(--font-mono); color:var(--text)">@SyncOptions.Value.DailyTime</span> · plus a catch-up run on startup</p>
    @if (_runs.Count == 0)
    {
        <p class="muted" style="padding:.5rem 0">No sync runs yet.</p>
    }
    else
    {
        <table class="sync-table">
            <tbody>
                @foreach (var run in _runs)
                {
                    var ok = run.Status == SyncStatus.Success;
                    <tr class="txn-row">
                        <td style="width:180px">
                            <span class="status-dot @(ok ? "ok" : "bad")"></span>
                            @run.RanAt.ToLocalTime().ToString("MMM d · h:mm tt")
                        </td>
                        <td style="width:100px; color:@(ok ? "var(--emerald)" : "var(--crimson)"); font-size:.82rem; font-weight:600">@run.Status</td>
                        <td>@run.NewTransactionCount new</td>
                        <td class="muted" style="font-size:.8rem">@run.Error</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private SimpleFinConnection? _connection;
    private string _setupToken = "";
    private bool _connecting;

    private List<CategoryRow> _categories = [];
    private string _newCategoryName = "";
    private string _newCategoryColor = "#4F46E5";

    private List<SyncRun> _runs = [];

    private bool _bannerOk;
    private string? _bannerMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _connection = await ConnectionService.GetConnectionAsync();

        await using var db = await DbFactory.CreateDbContextAsync();
        _categories = await db.Categories.AsNoTracking()
            .OrderBy(c => c.SortOrder).ThenBy(c => c.Name)
            .Select(c => new CategoryRow { Id = c.Id, Name = c.Name, Color = c.Color, SortOrder = c.SortOrder })
            .ToListAsync();
        _runs = await db.SyncRuns.AsNoTracking().OrderByDescending(r => r.RanAt).Take(10).ToListAsync();
    }

    private async Task ConnectAsync()
    {
        _connecting = true;
        _bannerMessage = null;
        try
        {
            await ConnectionService.ConnectAsync(_setupToken.Trim());
            _setupToken = "";
            _bannerOk = true;
            _bannerMessage = "Connected to SimpleFIN successfully.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _bannerOk = false;
            _bannerMessage = $"Connection failed: {ex.Message}";
        }
        finally
        {
            _connecting = false;
        }
    }

    private async Task SaveCategoryAsync(CategoryRow row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var category = await db.Categories.FirstOrDefaultAsync(c => c.Id == row.Id);
        if (category is not null)
        {
            category.Name = row.Name.Trim();
            category.Color = string.IsNullOrWhiteSpace(row.Color) ? null : row.Color!.Trim();
            category.SortOrder = row.SortOrder;
            await db.SaveChangesAsync();
        }

        await LoadAsync();
    }

    private async Task DeleteCategoryAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.Categories.Where(c => c.Id == id).ExecuteDeleteAsync();
        await LoadAsync();
    }

    private async Task AddCategoryAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var nextSort = _categories.Count == 0 ? 0 : _categories.Max(c => c.SortOrder) + 1;
        db.Categories.Add(new Category
        {
            Name = _newCategoryName.Trim(),
            Color = string.IsNullOrWhiteSpace(_newCategoryColor) ? null : _newCategoryColor.Trim(),
            IsSystem = false,
            SortOrder = nextSort,
        });
        await db.SaveChangesAsync();

        _newCategoryName = "";
        _newCategoryColor = "#4F46E5";
        await LoadAsync();
    }

    private sealed class CategoryRow
    {
        public int Id { get; init; }
        public string Name { get; set; } = "";
        public string? Color { get; set; }
        public int SortOrder { get; set; }
    }
}
